{
  "name": "logseq-toc-plugin",
  "author": "benjypng",
  "description": "Generate a table of contents for a given page.",
  "license": "MIT",
  "logseq": {
    "id": "logseq-toc-plugin",
    "title": "logseq-toc-plugin",
    "icon": "./icon.svg",
    "main": "dist/index.html"
  },
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "prepare": "husky",
    "lint:precommit": "echo \"Running biome\" && bunx @biomejs/biome check --write . && echo \"Running tsc\" && tsc --noEmit"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": ["logseq-toc-plugin.zip"]
        }
      ]
    ]
  },
  "dependencies": {
    "@logseq/libs": "^0.2.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^4.5.14",
    "vite-plugin-logseq": "^1.1.2",
    "vite-tsconfig-paths": "^4.3.2"
  }
}
